<?xml version="1.0" encoding="UTF-8"?>
<!-- Grails 7 migration: replaces log4j2.properties (Grails 7 / Spring Boot use logback) -->
<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <charset>UTF-8</charset>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${icescrum.log.dir:-logs}/icescrum.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${icescrum.log.dir:-logs}/icescrum.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <charset>UTF-8</charset>
            <pattern>%d [%thread] %-5level %logger %X - %msg%n</pattern>
        </encoder>
    </appender>

    <logger name="org.hibernate" level="ERROR"/>
    <!-- Surface schema generation failures, which are logged at WARN and would be hidden by the ERROR level above -->
    <logger name="org.hibernate.tool.schema" level="WARN"/>
    <logger name="org.springframework" level="ERROR"/>
    <logger name="org.atmosphere" level="WARN"/>
    <logger name="org.icescrum.atmosphere" level="WARN"/>
    <logger name="grails.plugin.springsecurity.web.access.intercept.AnnotationFilterInvocationDefinition" level="ERROR"/>

    <root level="INFO">
        <appender-ref ref="STDOUT"/>
        <appender-ref ref="FILE"/>
    </root>
</configuration>
